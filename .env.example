HOST=127.0.0.1
PORT=3000
PUBLIC_BASE_URL=https://vidpick.example.com
DATA_FILE=./data/state.json

OPENLIST_URL=http://127.0.0.1:5244
OPENLIST_TOKEN_FILE=/run/secrets/openlist-token.env
OPENLIST_ROOT=/
OPENLIST_DELETE_ENABLED=false
SCAN_CONCURRENCY=6

# 可选：优先使用 SmartSTRM 的本地 .strm 目录作为快速索引和播放源。
SMARTSTRM_ROOT=/smartstrm
SMARTSTRM_OPENLIST_BASE=/media
SMARTSTRM_ALLOWED_HOST=alist.example.com
